FLASK_APP=wsgi.py
FLASK_ENV=development
SECRET_KEY=change-me-in-production

# PostgreSQL
DATABASE_URL=postgresql://scrapemind:scrapemind@localhost:5432/scrapemind

# Redis (Faz 2 — Celery)
REDIS_URL=redis://localhost:6379/0

# OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth — Microsoft
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# Flask-Limiter storage
RATELIMIT_STORAGE_URL=memory://

# Email — MAIL_SERVER bos kalirsa dev modu (link flash'ta gosterilir).
# MAIL_USE_TLS (587/STARTTLS) ve MAIL_USE_SSL (465) ayni anda true OLMAMALI.
# MAIL_SUPPRESS_SEND'i bos birak (otomatik: MAIL_SERVER varsa gonder, yoksa suppress).
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@scrapemind.local
MAIL_SUPPRESS_SEND=

# --- Email yapilandirma ornekleri (yorum acip uyarla) ---
#
# 1) Mailhog (lokal dev — hicbir email gercek hedefe ulasmaz, http://localhost:8025'ten oku)
#    `docker compose --profile mail up -d` ile baslat.
# MAIL_SERVER=localhost
# MAIL_PORT=1025
# MAIL_USE_TLS=false
# MAIL_USE_SSL=false
# MAIL_USERNAME=
# MAIL_PASSWORD=
#
# 2) Gmail / Google Workspace (uygulamaya ozel sifre gerekli)
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=465
# MAIL_USE_TLS=false
# MAIL_USE_SSL=true
# MAIL_USERNAME=you@gmail.com
# MAIL_PASSWORD=<app-password>
#
# 3) Resend (https://resend.com — SMTP relay)
# MAIL_SERVER=smtp.resend.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=resend
# MAIL_PASSWORD=<RESEND_API_KEY>
#
# 4) Amazon SES (region'a gore endpoint degisir)
# MAIL_SERVER=email-smtp.eu-west-1.amazonaws.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=<SES_SMTP_USER>
# MAIL_PASSWORD=<SES_SMTP_PASSWORD>

# i18n
BABEL_DEFAULT_LOCALE=tr
BABEL_DEFAULT_TIMEZONE=Europe/Istanbul

# Anthropic Claude — paper AI analiz + TR ceviri.
# Bos kalirsa /papers/<id>?mode=ai zarif bir "yapilandirilmadi" paneli gosterir;
# uygulama crash etmez. Anahtarli sahip oldugun an feature aktif olur.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
